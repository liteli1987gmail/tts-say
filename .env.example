# Copy this file to .env and fill in your own values.

# Default provider: MiniMax
MINIMAX_API_KEY=

# Optional: use a trial relay instead of a local MiniMax key.
TTS_SAY_RELAY_URL=
TTS_SAY_TRIAL_TOKEN=

# Optional provider override: auto, minimax, relay, or macos.
TTS_SAY_PROVIDER=auto

# Optional macOS voice name, for example: Samantha, Ting-Ting, Mei-Jia.
TTS_SAY_MACOS_VOICE=
